تمرین 6
توان سوم اعداد 1 تا 10 را محاسبه کنید
#حل:
tavan=[value**3 for value in range(1,11)]
print(tavan)



تمرین 7
مجموع اعداد داخل یک لیست را با حلقه  حساب کنید
#حل:
numbers=[25,13,10,4,50]
sum=0
for i in numbers:
    sum=sum+i  #sum+=i
print(sum)




تمرین 6
با List Comprehension
لیست مربع اعداد 1 تا 20 را بسازید
#حل:
squares=[value**2 for value in range(1,21)]
print(squares)




تمرین 7
اعداد زوج بین 1 تا 50 را با List Comprehension تولید کنید
#حل:
numbers=[x for x in range(1,51) if x%2==0]
print(numbers)
